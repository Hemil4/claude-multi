#!/usr/bin/env bash
set -euo pipefail

# ─────────────────────────────────────────────────────────────────────────────
# claude-multi — Run multiple Claude Code accounts in parallel
#
# Features over claude-switch:
#   - Full flag forwarding (-r, -c, -p, etc.)
#   - Auto-shared sessions across all profiles
#   - Parallel accounts with isolated credentials
#   - Interactive menu with gum
# ─────────────────────────────────────────────────────────────────────────────

VERSION="1.1.0"
TOOL_NAME="claude-multi"
CLAUDE_HOME="$HOME/.claude"
PROFILE_PREFIX="$HOME/.claude-"
PROFILE_MARKER=".claude-multi-profile"
SHARED_ITEMS="skills plugins settings.json CLAUDE.md"
USAGE_DIR="$HOME/.claude-multi"
USAGE_FILE="$USAGE_DIR/usage.json"
HOOKS_DIR="$(cd "$(dirname "$0")" && pwd)/hooks"

# ── Colors ───────────────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ── Helpers ──────────────────────────────────────────────────────────────────

info()    { printf "  ${CYAN}>${RESET} %s\n" "$1"; }
success() { printf "  ${GREEN}✔${RESET} %s\n" "$1"; }
warn()    { printf "  ${YELLOW}!${RESET} %s\n" "$1"; }
error()   { printf "  ${RED}✘${RESET} %s\n" "$1"; exit 1; }
dim()     { printf "  ${DIM}  %s${RESET}\n" "$1"; }

profile_dir() { echo "${PROFILE_PREFIX}${1}"; }

profile_exists() {
    local dir
    dir="$(profile_dir "$1")"
    [ -d "$dir" ] && [ -f "$dir/$PROFILE_MARKER" ]
}

ensure_gum() {
    if command -v gum >/dev/null 2>&1; then
        return 0
    fi
    echo ""
    warn "gum is required for interactive menus."
    if command -v brew >/dev/null 2>&1; then
        info "Installing via Homebrew..."
        brew install gum
    else
        printf "  Install: ${CYAN}brew install gum${RESET}\n"
        exit 1
    fi
}

ensure_claude() {
    if ! command -v claude >/dev/null 2>&1; then
        error "Claude Code not found. Install it first: https://docs.anthropic.com/en/docs/claude-code"
    fi
}

validate_name() {
    local name="$1"
    if [ -z "$name" ]; then
        error "Profile name cannot be empty."
    fi
    if [ "$name" = "default" ]; then
        error "'default' is reserved for ~/.claude/"
    fi
    if [[ "$name" =~ [^a-zA-Z0-9_-] ]]; then
        error "Profile name can only contain letters, numbers, hyphens, and underscores."
    fi
}

list_profiles() {
    local found=0
    for dir in "${PROFILE_PREFIX}"*/; do
        [ -d "$dir" ] || continue
        [ -f "$dir/$PROFILE_MARKER" ] || continue
        basename "$dir" | sed "s/^\.claude-//"
        found=1
    done
    if [ "$found" -eq 0 ]; then
        return 1
    fi
}

pick_profile() {
    local action="${1:-select}"
    ensure_gum

    local profiles=()
    while IFS= read -r p; do
        profiles+=("$p")
    done < <(list_profiles 2>/dev/null || true)

    if [ ${#profiles[@]} -eq 0 ]; then
        error "No profiles found. Create one: $TOOL_NAME create <name>"
    fi

    local chosen
    chosen=$(printf '%s\n' "${profiles[@]}" | gum choose --header "  $action profile:")
    echo "$chosen"
}

# ── Header ───────────────────────────────────────────────────────────────────

print_header() {
    echo ""
    if command -v gum >/dev/null 2>&1; then
        gum style \
            --border double \
            --border-foreground 39 \
            --padding "1 3" \
            --margin "0 2" \
            --align center \
            "$(gum style --bold --foreground 39 'C L A U D E   M U L T I')" \
            "" \
            "$(gum style --faint "v${VERSION}  ·  parallel accounts · shared sessions · full flag support")"
    else
        printf "  ${BOLD}CLAUDE MULTI${RESET} v${VERSION}\n"
        printf "  ${DIM}parallel accounts · shared sessions · full flag support${RESET}\n"
    fi
    echo ""
}

# ── Commands ─────────────────────────────────────────────────────────────────

cmd_create() {
    local name="${1:-}"

    if [ -z "$name" ]; then
        ensure_gum
        name=$(gum input --placeholder "Profile name (e.g., work, personal)")
    fi

    validate_name "$name"

    local dir
    dir="$(profile_dir "$name")"

    if profile_exists "$name"; then
        error "Profile '$name' already exists."
    fi

    echo ""
    info "Creating profile: ${BOLD}$name${RESET}"

    # Create profile directory
    mkdir -p "$dir"

    # Drop marker file
    echo "$name" > "$dir/$PROFILE_MARKER"

    # Symlink shared config from default ~/.claude/
    for item in $SHARED_ITEMS; do
        local src="$CLAUDE_HOME/$item"
        local dst="$dir/$item"
        if [ -e "$src" ] && [ ! -e "$dst" ]; then
            ln -s "$src" "$dst"
            dim "Linked $item"
        fi
    done

    # Symlink projects folder for shared sessions
    if [ -d "$CLAUDE_HOME/projects" ]; then
        if [ ! -e "$dir/projects" ]; then
            ln -s "$CLAUDE_HOME/projects" "$dir/projects"
            success "Sessions shared (symlinked projects/)"
        fi
    fi

    # Create necessary directories
    mkdir -p "$dir/cache" "$dir/sessions" "$dir/backups"

    echo ""
    success "Profile '${name}' created!"
    echo ""
    info "Next step — log in:"
    dim "$TOOL_NAME $name"
    dim "Then type /login inside Claude Code"
    echo ""
}

cmd_list() {
    print_header

    local found=0
    local profiles=()

    while IFS= read -r name; do
        profiles+=("$name")
    done < <(list_profiles 2>/dev/null || true)

    if [ ${#profiles[@]} -eq 0 ]; then
        warn "No profiles yet."
        dim "Create one: $TOOL_NAME create <name>"
        echo ""
        return
    fi

    printf "  ${BOLD}%-15s %-12s %-8s %s${RESET}\n" "PROFILE" "STATUS" "SHARED" "DIRECTORY"
    printf "  ${DIM}%-15s %-12s %-8s %s${RESET}\n" "───────" "──────" "──────" "─────────"

    for name in "${profiles[@]}"; do
        local dir
        dir="$(profile_dir "$name")"

        # Check login status
        local status="${RED}not logged in${RESET}"
        if [ -f "$dir/.claude.json" ]; then
            local size
            size=$(wc -c < "$dir/.claude.json" | tr -d ' ')
            if [ "$size" -gt 100 ]; then
                status="${GREEN}logged in${RESET}"
            fi
        fi

        # Check session sharing
        local shared="${RED}no${RESET}"
        if [ -L "$dir/projects" ]; then
            shared="${GREEN}yes${RESET}"
        fi

        printf "  %-15s %-23s %-19s %s\n" "$name" "$status" "$shared" "$dir"
        found=1
    done

    echo ""

    if [ "$found" -eq 0 ]; then
        warn "No profiles found."
        dim "Create one: $TOOL_NAME create <name>"
        echo ""
    fi
}

cmd_delete() {
    local name="${1:-}"

    if [ -z "$name" ]; then
        name=$(pick_profile "Delete") || exit 1
    fi

    validate_name "$name"

    if ! profile_exists "$name"; then
        error "Profile '$name' does not exist."
    fi

    local dir
    dir="$(profile_dir "$name")"

    echo ""
    warn "This will delete profile '${name}' and its config at:"
    dim "$dir"
    echo ""

    if command -v gum >/dev/null 2>&1; then
        gum confirm "Delete profile '$name'?" || { info "Cancelled."; exit 0; }
    else
        printf "  Delete? [y/N] "
        read -r confirm
        [[ "$confirm" =~ ^[Yy]$ ]] || { info "Cancelled."; exit 0; }
    fi

    rm -rf "$dir"
    echo ""
    success "Profile '$name' deleted."
    echo ""
}

cmd_launch() {
    local name="${1:-}"

    if [ -z "$name" ]; then
        name=$(pick_profile "Launch") || exit 1
    fi

    if ! profile_exists "$name"; then
        error "Profile '$name' does not exist. Create it: $TOOL_NAME create $name"
    fi

    ensure_claude

    local dir
    dir="$(profile_dir "$name")"

    # Remove profile name from args, keep everything else (flags like -r, -c, -p)
    shift || true

    exec env CLAUDE_CONFIG_DIR="$dir" claude "$@"
}

cmd_status() {
    echo ""
    info "Checking active Claude processes..."
    echo ""

    local count=0
    while IFS= read -r line; do
        if [ -n "$line" ]; then
            printf "  %s\n" "$line"
            count=$((count + 1))
        fi
    done < <(ps aux | grep -E "CLAUDE_CONFIG_DIR.*claude" | grep -v grep || true)

    if [ "$count" -eq 0 ]; then
        dim "No active Claude sessions found."
    else
        echo ""
        success "$count active session(s)"
    fi
    echo ""
}

cmd_share() {
    local name="${1:-}"

    if [ -z "$name" ]; then
        name=$(pick_profile "Share sessions for") || exit 1
    fi

    if ! profile_exists "$name"; then
        error "Profile '$name' does not exist."
    fi

    local dir
    dir="$(profile_dir "$name")"

    if [ -L "$dir/projects" ]; then
        success "Sessions already shared for '$name'."
        return
    fi

    if [ -d "$dir/projects" ]; then
        warn "Profile '$name' has its own projects/ folder."
        info "Moving existing sessions to backup..."
        mv "$dir/projects" "$dir/projects.bak.$(date +%s)"
    fi

    ln -s "$CLAUDE_HOME/projects" "$dir/projects"
    success "Sessions now shared for '$name'."
    dim "All profiles can resume each other's sessions."
    echo ""
}

# ── Usage Monitoring ─────────────────────────────────────────────────────

cmd_setup_hooks() {
    echo ""
    info "Setting up usage tracking hooks..."

    # Find the hook script
    local hook_script=""
    if [ -f "$HOOKS_DIR/usage-tracker.py" ]; then
        hook_script="$HOOKS_DIR/usage-tracker.py"
    elif [ -f "$HOME/.local/share/claude-multi/hooks/usage-tracker.py" ]; then
        hook_script="$HOME/.local/share/claude-multi/hooks/usage-tracker.py"
    else
        error "Hook script not found. Reinstall claude-multi."
    fi

    # Create usage directory
    mkdir -p "$USAGE_DIR"

    # Install hook into default ~/.claude/settings.json
    local settings_file="$CLAUDE_HOME/settings.json"

    if [ ! -f "$settings_file" ]; then
        echo '{}' > "$settings_file"
    fi

    # Check if hook already exists
    if grep -q "usage-tracker" "$settings_file" 2>/dev/null; then
        success "Usage hook already installed in settings.json"
        echo ""
        return
    fi

    # Use python to safely merge the hook into settings.json
    python3 -c "
import json, sys

settings_path = '$settings_file'
hook_command = 'python3 $hook_script'

with open(settings_path, 'r') as f:
    settings = json.load(f)

if 'hooks' not in settings:
    settings['hooks'] = {}

if 'Stop' not in settings['hooks']:
    settings['hooks']['Stop'] = []

# Claude Code hook format: matcher + hooks array
settings['hooks']['Stop'].append({
    'matcher': '',
    'hooks': [
        {
            'type': 'command',
            'command': hook_command
        }
    ]
})

with open(settings_path, 'w') as f:
    json.dump(settings, f, indent=2)

print('ok')
" && success "Usage hook installed in $settings_file" || error "Failed to install hook"

    echo ""
    info "Hook will track real token usage after every Claude response."
    info "Run ${CYAN}$TOOL_NAME monitor${RESET} to see live usage."
    echo ""
}

cmd_remove_hooks() {
    echo ""
    info "Removing usage tracking hooks..."

    local settings_file="$CLAUDE_HOME/settings.json"

    if [ ! -f "$settings_file" ]; then
        warn "No settings file found."
        return
    fi

    python3 -c "
import json

settings_path = '$settings_file'

with open(settings_path, 'r') as f:
    settings = json.load(f)

if 'hooks' in settings and 'Stop' in settings['hooks']:
    # Filter out any entry containing usage-tracker in nested hooks
    new_stop = []
    for entry in settings['hooks']['Stop']:
        inner = entry.get('hooks', [])
        filtered = [h for h in inner if 'usage-tracker' not in h.get('command', '')]
        if filtered:
            entry['hooks'] = filtered
            new_stop.append(entry)
    settings['hooks']['Stop'] = new_stop
    if not settings['hooks']['Stop']:
        del settings['hooks']['Stop']
    if not settings['hooks']:
        del settings['hooks']

with open(settings_path, 'w') as f:
    json.dump(settings, f, indent=2)

print('ok')
" && success "Usage hook removed." || error "Failed to remove hook"
    echo ""
}

cmd_setup_statusline() {
    echo ""
    info "Setting up usage status line..."

    # Find the statusline script
    local sl_script=""
    if [ -f "$HOOKS_DIR/usage-statusline.sh" ]; then
        sl_script="$HOOKS_DIR/usage-statusline.sh"
    elif [ -f "$HOME/.local/share/claude-multi/hooks/usage-statusline.sh" ]; then
        sl_script="$HOME/.local/share/claude-multi/hooks/usage-statusline.sh"
    else
        error "Statusline script not found. Reinstall claude-multi."
    fi

    # Check jq dependency
    if ! command -v jq >/dev/null 2>&1; then
        warn "jq is required for the status line."
        if command -v brew >/dev/null 2>&1; then
            info "Installing via Homebrew..."
            brew install jq
        else
            error "Install jq first: brew install jq"
        fi
    fi

    local settings_file="$CLAUDE_HOME/settings.json"
    if [ ! -f "$settings_file" ]; then
        echo '{}' > "$settings_file"
    fi

    # Check if statusline already exists
    if grep -q "usage-statusline" "$settings_file" 2>/dev/null; then
        success "Status line already configured."
        echo ""
        return
    fi

    python3 -c "
import json

settings_path = '$settings_file'
sl_command = 'bash $sl_script'

with open(settings_path, 'r') as f:
    settings = json.load(f)

settings['statusLine'] = {
    'type': 'command',
    'command': sl_command,
    'refreshInterval': 10
}

with open(settings_path, 'w') as f:
    json.dump(settings, f, indent=2)

print('ok')
" && success "Status line configured in $settings_file" || error "Failed to configure status line"

    echo ""
    info "You'll see real-time usage at the bottom of Claude Code:"
    dim "work Opus | ██░░░░░░░░ 15% reset 4:30PM | Wk: 48% | Ctx: 35%"
    echo ""
    info "Restart Claude Code to activate."
    echo ""
}

cmd_remove_statusline() {
    echo ""
    info "Removing status line..."

    local settings_file="$CLAUDE_HOME/settings.json"
    if [ ! -f "$settings_file" ]; then
        warn "No settings file found."
        return
    fi

    python3 -c "
import json

settings_path = '$settings_file'

with open(settings_path, 'r') as f:
    settings = json.load(f)

if 'statusLine' in settings:
    del settings['statusLine']

with open(settings_path, 'w') as f:
    json.dump(settings, f, indent=2)

print('ok')
" && success "Status line removed." || error "Failed to remove"
    echo ""
}

cmd_setup() {
    echo ""
    print_header
    info "Running full setup..."
    echo ""
    cmd_setup_hooks
    cmd_setup_statusline
    success "All done! Restart Claude Code to see the status line."
    echo ""
}

cmd_monitor() {
    if [ ! -f "$USAGE_FILE" ]; then
        echo ""
        warn "No usage data yet."
        info "Run ${CYAN}$TOOL_NAME setup-hooks${RESET} first to start tracking."
        echo ""
        return
    fi

    local watch_mode="${1:-}"

    if [ "$watch_mode" = "--watch" ] || [ "$watch_mode" = "-w" ]; then
        # Live auto-refresh mode
        while true; do
            clear
            render_monitor
            sleep 10
        done
    else
        render_monitor
    fi
}

render_monitor() {
    local now
    now=$(date +%s)

    echo ""
    if command -v gum >/dev/null 2>&1; then
        gum style \
            --border rounded \
            --border-foreground 39 \
            --padding "0 2" \
            --margin "0 1" \
            --align center \
            "$(gum style --bold --foreground 39 'USAGE MONITOR')" \
            "$(gum style --faint "real token data · 5h rolling window")"
    else
        printf "  ${BOLD}USAGE MONITOR${RESET}\n"
        printf "  ${DIM}real token data · 5h rolling window${RESET}\n"
    fi
    echo ""

    # Parse usage data with python
    python3 -c "
import json, time, sys
from datetime import datetime, timezone

now = time.time()
window = 5 * 60 * 60

with open('$USAGE_FILE', 'r') as f:
    data = json.load(f)

profiles = data.get('profiles', {})
if not profiles:
    print('  No profiles tracked yet.')
    sys.exit(0)

# Colors
GREEN = '\033[0;32m'
YELLOW = '\033[0;33m'
RED = '\033[0;31m'
CYAN = '\033[0;36m'
BOLD = '\033[1m'
DIM = '\033[2m'
RESET = '\033[0m'

for name, pdata in sorted(profiles.items()):
    entries = [e for e in pdata.get('entries', []) if e.get('recorded_at', 0) > now - window]

    input_t = sum(e.get('input_tokens', 0) for e in entries)
    output_t = sum(e.get('output_tokens', 0) for e in entries)
    cache_read = sum(e.get('cache_read_input_tokens', 0) for e in entries)
    cache_create = sum(e.get('cache_creation_input_tokens', 0) for e in entries)
    total_tokens = input_t + output_t + cache_read + cache_create
    msg_count = len(entries)
    model = pdata.get('last_model', 'unknown')

    # Reset time
    resets_at = pdata.get('window_resets_at', now)
    if entries:
        oldest = min(e.get('recorded_at', now) for e in entries)
        resets_at = oldest + window

    remaining = max(0, resets_at - now)
    hours = int(remaining // 3600)
    minutes = int((remaining % 3600) // 60)

    # Usage bar (estimate based on common Max limits ~45M tokens/5h)
    # User can override this, but 45M is a reasonable default
    estimated_limit = 45_000_000
    pct = min(100, int((total_tokens / estimated_limit) * 100)) if estimated_limit > 0 else 0

    # Color based on usage
    if pct < 50:
        bar_color = GREEN
    elif pct < 80:
        bar_color = YELLOW
    else:
        bar_color = RED

    filled = int(pct / 5)
    empty = 20 - filled
    bar = f'{bar_color}{\"█\" * filled}{DIM}{\"░\" * empty}{RESET}'

    # Format tokens
    def fmt(n):
        if n >= 1_000_000:
            return f'{n/1_000_000:.1f}M'
        elif n >= 1_000:
            return f'{n/1_000:.1f}K'
        return str(n)

    print(f'  {BOLD}{name}{RESET}  {DIM}({model}){RESET}')
    print(f'  {bar}  {pct}%')
    print(f'  {CYAN}Messages:{RESET} {msg_count}   {CYAN}Tokens:{RESET} {fmt(total_tokens)}   {CYAN}Output:{RESET} {fmt(output_t)}')
    print(f'  {CYAN}Cache read:{RESET} {fmt(cache_read)}   {CYAN}Cache create:{RESET} {fmt(cache_create)}')
    print(f'  {CYAN}Window resets in:{RESET} {hours}h {minutes}m')
    print()

print(f'  {DIM}Last updated: {datetime.now().strftime(\"%H:%M:%S\")}{RESET}')
print(f'  {DIM}Run with --watch for live refresh{RESET}')
"
    echo ""
}

cmd_help() {
    print_header
    printf "  ${BOLD}USAGE${RESET}\n"
    printf "    $TOOL_NAME ${DIM}<profile> [claude-flags]${RESET}     Launch with any Claude flags\n"
    printf "    $TOOL_NAME ${DIM}<command> [args]${RESET}             Manage profiles\n\n"

    printf "  ${BOLD}COMMANDS${RESET}\n"
    printf "    ${CYAN}create${RESET} ${DIM}[name]${RESET}       Create a profile (auto-shares sessions)\n"
    printf "    ${CYAN}list${RESET}               Show all profiles + login & sharing status\n"
    printf "    ${CYAN}delete${RESET} ${DIM}[name]${RESET}       Delete a profile\n"
    printf "    ${CYAN}share${RESET} ${DIM}[name]${RESET}        Enable session sharing for a profile\n"
    printf "    ${CYAN}status${RESET}             Show active Claude sessions\n"
    printf "    ${CYAN}monitor${RESET} ${DIM}[-w]${RESET}       Show real-time token usage dashboard\n"
    printf "    ${CYAN}setup${RESET}              Install status line + usage hooks (one-time)\n"
    printf "    ${CYAN}setup-hooks${RESET}        Install usage tracking hook only\n"
    printf "    ${CYAN}setup-statusline${RESET}   Install status line only\n"
    printf "    ${CYAN}remove-hooks${RESET}       Remove usage tracking hook\n"
    printf "    ${CYAN}remove-statusline${RESET}  Remove status line\n"
    printf "    ${CYAN}help${RESET}               Show this help\n"
    printf "    ${CYAN}version${RESET}            Show version\n\n"

    printf "  ${BOLD}EXAMPLES${RESET}\n"
    printf "    ${DIM}$TOOL_NAME work${RESET}                  Launch work profile\n"
