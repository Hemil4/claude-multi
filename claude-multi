}

# ── Main ─────────────────────────────────────────────────────────────────────

main() {
    case "${1:-}" in
        create)              shift; cmd_create "$@" ;;
        list|ls)             shift; cmd_list "$@" ;;
        delete|rm|remove)    shift; cmd_delete "$@" ;;
        share)               shift; cmd_share "$@" ;;
        status|ps)           shift; cmd_status "$@" ;;
        monitor)             shift; cmd_monitor "$@" ;;
        setup)               shift; cmd_setup "$@" ;;
        setup-hooks)         shift; cmd_setup_hooks "$@" ;;
        setup-statusline)    shift; cmd_setup_statusline "$@" ;;
        remove-hooks)        shift; cmd_remove_hooks "$@" ;;
        remove-statusline)   shift; cmd_remove_statusline "$@" ;;
        launch|run|start)    shift; cmd_launch "$@" ;;
        help|-h|--help)      cmd_help ;;
        version|-v|--version) echo "$TOOL_NAME v$VERSION" ;;
        "")
            ensure_gum
            print_header
            local action
            action=$(gum choose \
                "Launch a profile" \
                "Create a profile" \
                "List profiles" \
                "Usage monitor" \
                "Setup usage hooks" \
                "Show active sessions" \
                "Delete a profile" \
                "Exit")
            case "$action" in
                "Launch a profile")      cmd_launch ;;
                "Create a profile")      cmd_create ;;
                "List profiles")         cmd_list ;;
                "Usage monitor")         cmd_monitor ;;
                "Setup usage hooks")     cmd_setup_hooks ;;
                "Show active sessions")  cmd_status ;;
                "Delete a profile")      cmd_delete ;;
                "Exit"|"")               exit 0 ;;
            esac
            ;;
        *)
            # If arg matches a profile name, launch it (with remaining flags)
            if profile_exists "$1"; then
                cmd_launch "$@"
            else
                error "Unknown command or profile: $1. Run '$TOOL_NAME help' for usage."
            fi
            ;;
    esac
}

main "$@"
